# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# IDE - IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# IDE - Eclipse
.project
.classpath
.settings/

# IDE - VS Code
.vscode/

# Claude Code local settings (machine-specific tool permissions, not project config)
.claude/

# Spring Boot
*.log
logs/
spring.log

# Uploaded files (user content — not tracked in git)
uploads/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment-specific properties with real local secrets (never committed).
# application-prod.properties and application-dev.properties themselves ARE
# tracked - they only contain ${ENV_VAR} placeholders, never live credentials.
application-local.properties
*.env
.env
.env.*

# Local database files (legacy H2 artifacts — every environment now uses Neon
# PostgreSQL, but these are excluded in case any local file DB is ever created)
data/
*.mv.db
*.trace.db

# Sensitive files
secrets.properties
